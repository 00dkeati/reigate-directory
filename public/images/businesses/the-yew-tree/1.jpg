    applyScrollFreeze() {
        const dbStyle = document.body.style;
        if (this.freezeScroll) {
            this.scrollPos = -window.scrollY;
            dbStyle.top = this.scrollPos + 'px';
            dbStyle.position = 'fixed';
            dbStyle.overflow = 'hidden';
        } else {
            dbStyle.top = '';
            dbStyle.position = '';
            dbStyle.overflow = '';
            if (this.scrollPos) {
                window.scrollTo(0, -this.scrollPos);
                this.scrollPos = 0;
            }
        }
    },

